DATABASE_URL=postgresql://dotask:dotask@localhost:5432/dotask?schema=public
REDIS_URL=redis://localhost:6379
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=a-32-char-minimum-secret-string!
WORKOS_REDIRECT_URI=http://localhost:3000/v1/auth/callback
FRONTEND_URL=http://localhost:5173
PORT=3000

# Login fijo solo en local (nunca en producción: NODE_ENV=production lo bloquea)
DOTASK_DEV_LOGIN=true
DOTASK_DEV_LOGIN_PASSWORD=dotask-dev
# Opcional: usuario creado/actualizado en BD
# DOTASK_DEV_LOGIN_EMAIL=dev@dotask.local
# DOTASK_DEV_LOGIN_NAME=Usuario local (dev)
